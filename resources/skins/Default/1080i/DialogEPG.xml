                    <posy>30</posy>
                    <width>28</width>
                    <height>28</height>
                    <texture>icon_chevron_left.png</texture>
                </control>
                <control type="image">
                    <posx>34</posx>
                    <posy>30</posy>
                    <width>28</width>
                    <height>28</height>
                    <texture>icon_chevron_right.png</texture>
                </control>
                <control type="label">
                    <posx>76</posx>
                    <posy>0</posy>
                    <width>420</width>
                    <height>88</height>
                    <aligny>center</aligny>
                    <font>font12</font>
                    <textcolor>FFE6E6E6</textcolor>
                    <label>ESQ/DIR: MUDAR PAINEL</label>
