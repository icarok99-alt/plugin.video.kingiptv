                        <aligny>center</aligny>
                        <font>font12</font>
                        <textcolor>FFF3B73B</textcolor>
                        <label>$INFO[ListItem.Property(range)]</label>
                    </control>
                    <control type="label">
                        <posx>190</posx>
                        <posy>0</posy>
                        <width>642</width>
                        <height>62</height>
                        <aligny>center</aligny>
                        <font>font12</font>
                        <textcolor>FFD8D8D8</textcolor>
                        <label>$INFO[ListItem.Label]</label>
                    </control>
                </itemlayout>
                <focusedlayout width="832" height="62">
                    <control type="image">
                        <posx>0</posx>
                        <posy>0</posy>
                        <width>832</width>
                        <height>62</height>
                        <texture>epg_upcoming_row.png</texture>
                    </control>
                    <control type="label">
                        <posx>0</posx>
                        <posy>0</posy>
                        <width>170</width>
                        <height>62</height>
                        <aligny>center</aligny>
                        <font>font12</font>
                        <textcolor>FFFFFFFF</textcolor>
                        <label>$INFO[ListItem.Property(range)]</label>
                    </control>
                    <control type="label">
                        <posx>190</posx>
                        <posy>0</posy>
                        <width>642</width>
                        <height>62</height>
