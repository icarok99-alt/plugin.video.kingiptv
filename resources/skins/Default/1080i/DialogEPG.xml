        <!-- ============ BARRA INFERIOR: ATALHOS (sem coroa) ============ -->
        <control type="group">
            <posx>0</posx>
            <posy>992</posy>

            <control type="image">
                <posx>0</posx>
                <posy>0</posy>
                <width>1920</width>
                <height>88</height>
                <texture>epg_bottombar_bg.png</texture>
            </control>

            <control type="group">
                <posx>60</posx>
                <posy>0</posy>
                <control type="image">
