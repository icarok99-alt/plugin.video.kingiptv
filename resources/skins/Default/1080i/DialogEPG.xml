        <!-- ============ PAINEL ESQUERDO: LISTA DE CANAIS ============ -->
        <!--
            Contrato de dados por item (ListItem):
              Label              -> nome do canal
              Icon / Thumb       -> logo do canal
              Property(current)  -> nome do programa atual ("AGORA")
              Property(percent)  -> 0-100, progresso do programa atual
              Property(live)     -> "true" se há programa em exibição
        -->
        <control type="group">
            <posx>40</posx>
            <posy>118</posy>

            <control type="list" id="3001">
                <posx>0</posx>
                <posy>0</posy>
                <width>880</width>
                <height>860</height>
                <onleft>3001</onleft>
                <onright>3002</onright>
                <onup>3010</onup>
                <ondown>3001</ondown>
                <scrolltime>200</scrolltime>
                <itemlayout width="880" height="118">
                    <control type="image">
                        <posx>0</posx>
                        <posy>4</posy>
                        <width>860</width>
                        <height>112</height>
                        <texture>epg_item_normal.png</texture>
                    </control>
                    <control type="image">
                        <posx>16</posx>
                        <posy>20</posy>
                        <width>132</width>
                        <height>80</height>
                        <texture fallback="icon.png">$INFO[ListItem.Icon]</texture>
                        <aspectratio aligny="center" align="center">keep</aspectratio>
                    </control>
                    <control type="label">
                        <posx>170</posx>
                        <posy>16</posy>
                        <width>660</width>
                        <height>34</height>
                        <font>font13</font>
                        <textcolor>FFE6E6E6</textcolor>
                        <label>$INFO[ListItem.Label]</label>
                    </control>
                    <control type="label">
                        <posx>170</posx>
                        <posy>50</posy>
                        <width>660</width>
                        <height>30</height>
                        <font>font12</font>
                        <textcolor>FFF3B73B</textcolor>
                        <label>$INFO[ListItem.Property(current)]</label>
                    </control>
                    <control type="progress">
                        <posx>170</posx>
                        <posy>88</posy>
                        <width>420</width>
                        <height>6</height>
                        <texturebg>epg_progress_mini_track.png</texturebg>
                        <lefttexture>epg_progress_mini_fill_left.png</lefttexture>
                        <midtexture>epg_progress_mini_fill_mid.png</midtexture>
                        <righttexture>epg_progress_mini_fill_right.png</righttexture>
                        <info>ListItem.Property(percent)</info>
                        <visible>!String.IsEmpty(ListItem.Property(current))</visible>
                    </control>
                </itemlayout>
                <focusedlayout width="880" height="118">
                    <control type="image">
                        <posx>0</posx>
                        <posy>4</posy>
                        <width>860</width>
                        <height>112</height>
                        <texture>epg_item_focused.png</texture>
                    </control>
                    <control type="image">
                        <posx>16</posx>
                        <posy>20</posy>
                        <width>132</width>
                        <height>80</height>
                        <texture fallback="icon.png">$INFO[ListItem.Icon]</texture>
                        <aspectratio aligny="center" align="center">keep</aspectratio>
                    </control>
                    <control type="label">
                        <posx>170</posx>
                        <posy>16</posy>
                        <width>660</width>
                        <height>34</height>
                        <font>font13</font>
                        <textcolor>FFFFFFFF</textcolor>
                        <label>$INFO[ListItem.Label]</label>
                    </control>
                    <control type="label">
                        <posx>170</posx>
                        <posy>50</posy>
                        <width>660</width>
                        <height>30</height>
                        <font>font12</font>
                        <textcolor>FFF3B73B</textcolor>
                        <label>$INFO[ListItem.Property(current)]</label>
                    </control>
                    <control type="progress">
                        <posx>170</posx>
                        <posy>88</posy>
                        <width>420</width>
                        <height>6</height>
                        <texturebg>epg_progress_mini_track.png</texturebg>
                        <lefttexture>epg_progress_mini_fill_left.png</lefttexture>
                        <midtexture>epg_progress_mini_fill_mid.png</midtexture>
                        <righttexture>epg_progress_mini_fill_right.png</righttexture>
                        <info>ListItem.Property(percent)</info>
                        <visible>!String.IsEmpty(ListItem.Property(current))</visible>
                    </control>
                </focusedlayout>
            </control>
        </control>

        <!-- ============ PAINEL DIREITO: DETALHES DO PROGRAMA ============ -->
