                <aspectratio>keep</aspectratio>
            </control>

            <control type="label">
                <posx>112</posx>
                <posy>0</posy>
                <width>1100</width>
                <height>100</height>
                <aligny>center</aligny>
                <font>font15_title</font>
                <textcolor>FFF3B73B</textcolor>
                <label>$INFO[Window(Home).Property(epg.header)]  |  GUIA DE PROGRAMAÇÃO</label>
            </control>

            <control type="label">
                <posx>1300</posx>
                <posy>0</posy>
                <width>420</width>
                <height>100</height>
                <align>right</align>
                <aligny>center</aligny>
                <font>font12</font>
                <textcolor>FFF3B73B</textcolor>
                <label>$INFO[System.Date]</label>
            </control>

            <control type="label">
                <posx>1740</posx>
                <posy>0</posy>
                <width>140</width>
                <height>100</height>
                <align>right</align>
                <aligny>center</aligny>
                <font>font15_title</font>
