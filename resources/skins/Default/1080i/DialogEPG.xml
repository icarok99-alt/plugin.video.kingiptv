<?xml version="1.0" encoding="UTF-8"?>
<!--
    DialogEPG.xml - Guia de Programacao (TV AO VIVO / PLUTO TV)

    Janela reutilizavel para as duas secoes do addon (Live TV / Xtream
    e Pluto TV). O título exibido na barra superior é controlado pela
    propriedade "epg.header" (ex.: "TV AO VIVO" ou "PLUTO TV"),
    definida pelo Python antes de abrir o diálogo (ver lib/epg_dialog.py).

    Regras de design seguidas:
      - Nenhum ícone/emblema de coroa foi usado na barra inferior de
        atalhos (apenas ícones neutros: OK, lista, setas, voltar).
      - Nenhuma coroa e nenhum nome de categoria/gênero aparece nas
        linhas da lista de canais (painel esquerdo do EPG). Cada linha
        mostra apenas: logo do canal, nome do canal, programa atual e
        uma mini barra de progresso.
      - Nenhum emoji é usado em nenhum label; todos os ícones são
        texturas PNG reais (icon_*.png / epg_*.png).
-->
<window>
    <onload>SetProperty(epg.active,true)</onload>
    <onunload>ClearProperty(epg.active)</onunload>

    <controls>

        <!-- ============ FUNDO ============ -->
        <control type="image">
            <posx>0</posx>
            <posy>0</posy>
            <width>1920</width>
            <height>1080</height>
            <texture fallback="epg_fanart.jpg">$INFO[Window(Home).Property(epg.fanart)]</texture>
            <aspectratio>scale</aspectratio>
        </control>

        <control type="image">
            <posx>0</posx>
            <posy>0</posy>
            <width>1920</width>
            <height>1080</height>
            <texture>epg_bg_gradient.png</texture>
        </control>

        <!-- ============ BARRA SUPERIOR ============ -->
        <control type="group">
            <posx>0</posx>
            <posy>0</posy>

            <control type="image">
                <posx>0</posx>
                <posy>0</posy>
                <width>1920</width>
                <height>100</height>
                <texture>epg_topbar_bg.png</texture>
            </control>

            <control type="button" id="3010">
                <posx>20</posx>
                <posy>8</posy>
                <width>760</width>
                <height>84</height>
